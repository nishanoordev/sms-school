{
  "name": "school-system-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "management-portal",
    "management-portal"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w management-portal\"",
    "build": "npm run build --workspaces",
    "start": "npm start -w backend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
