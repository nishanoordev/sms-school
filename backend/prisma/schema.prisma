// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id               String       @id @default(uuid())
  admissionNumber  String       @unique
  name             String
  dob              DateTime
  gender           String
  aadhaarNumber    String?
  bloodGroup       String
  religion         String
  motherTongue     String
  category         String
  fatherName       String
  motherName       String
  fatherAadhaar    String?
  motherAadhaar    String?
  parentContact    String
  emergencyContact String
  email            String?
  address          String
  pinCode          String
  district         String
  state            String
  classId          String
  section          String
  medium           String
  isRTE            Boolean      @default(false)
  status           String       @default("Active")
  attendance       Attendance[]
  grades           Grade[]
  fees             Fee[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Teacher {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  name          String
  qualification String
  dateOfJoining DateTime
  assignedClass String?
  subjects      String[]
  contact       String
  email         String?
  aadhaar       String?
  salary        Float?
  designation   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  date      DateTime
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

model Grade {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  term      String
  subject   String
  mark      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fee {
  id        String    @id @default(uuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id])
  head      String
  amount    Float
  paid      Boolean   @default(false)
  receiptNo String?
  paidDate  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Notice {
  id         String   @id @default(uuid())
  title      String
  content    String
  category   String
  date       String
  expiryDate String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LeaveRequest {
  id          String   @id @default(uuid())
  staffId     String
  staffName   String
  type        String
  fromDate    String
  toDate      String
  reason      String
  status      String   @default("Pending")
  appliedDate String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalaryRecord {
  id          String   @id @default(uuid())
  staffId     String
  staffName   String
  month       String
  basicSalary Float
  allowances  Float
  deductions  Float
  netSalary   Float
  status      String   @default("Pending")
  paidDate    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Homework {
  id           String   @id @default(uuid())
  classId      String
  subjectName  String
  title        String
  description  String
  assignedDate String
  dueDate      String
  teacherName  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExamSchedule {
  id          String   @id @default(uuid())
  examName    String
  classId     String
  subjectName String
  date        String
  startTime   String
  endTime     String
  venue       String
  totalMarks  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  date        String
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicCalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  description String?
  category    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeeReceipt {
  id              String   @id @default(uuid())
  receiptNo       String   @unique
  studentId       String
  studentName     String
  admissionNumber String
  classId         String
  feeHead         String
  amount          Float
  paymentMode     String
  date            String
  collectedBy     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String
  classId   String
  teacherId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassRoom {
  id             String   @id @default(uuid())
  name           String   @unique
  sections       String[]
  capacity       Int
  classTeacherId String?
  medium         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GalleryItem {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  category    String?  @default("School")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("New")
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}


